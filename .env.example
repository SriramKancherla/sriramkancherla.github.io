# Public site URL (no trailing slash) — used for sitemap, canonical, and Open Graph tags at build time
VITE_SITE_URL=https://sriramkancherla.pages.dev

# Base path — only needed for project sites (e.g. /portfolio/). Omit for username.pages.dev.
# VITE_BASE_PATH=/portfolio/

# Web3Forms access key — set this in Cloudflare Pages as a RUNTIME env var (no VITE_ prefix):
#   Name:  WEB3FORMS_ACCESS_KEY
#   Value: your Web3Forms access key
# The contact form posts to /api/contact (Pages Function), which reads this secret server-side.
# Do NOT use VITE_WEB3FORMS_ACCESS_KEY anymore — that embeds the key in the public JS bundle.
